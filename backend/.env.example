# Copie este arquivo para .env e preencha com seus dados
# cp .env.example .env

# ── Servidor ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Banco de dados (PostgreSQL) ──────────────────────────────
DATABASE_URL=postgresql://usuario:senha@localhost:5432/beeplanner

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=troque_por_uma_chave_longa_e_aleatoria_aqui
JWT_EXPIRES=7d

# ── URLs ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:3001

# ── Google OAuth2 (opcional) ─────────────────────────────────
# Crie em: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ── GitHub OAuth2 (opcional) ─────────────────────────────────
# Crie em: https://github.com/settings/developers → New OAuth App
# Authorization callback URL: http://localhost:3001/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback
